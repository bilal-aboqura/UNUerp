# Google Apps Script / approved server-side webhook URL. Keep server-only: never use NEXT_PUBLIC_.
# Without this value, submissions are logged only in development and return 503 in production.
DEMO_REQUEST_WEBHOOK_URL=

# Shared secret sent only from this server to authenticate the webhook. It is never exposed to the browser.
# For Google Apps Script, set this to the same value as WEBHOOK_SHARED_SECRET in Script properties.
DEMO_REQUEST_WEBHOOK_TOKEN=
